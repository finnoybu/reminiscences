---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getDb, schema } from '~/db';
import { isAuthConfigured, getEnv } from '~/lib/env';
import { and, eq } from 'drizzle-orm';

// SSR so we can flip the PDF/ePub tile to "Purchased" if the user owns it.
export const prerender = false;

const user = Astro.locals.user;
const env = getEnv(Astro);

let owns = false;
if (user && isAuthConfigured(env)) {
  try {
    const db = getDb(Astro);
    const [hit] = await db
      .select({ id: schema.purchases.id })
      .from(schema.purchases)
      .where(
        and(
          eq(schema.purchases.userId, user.id),
          eq(schema.purchases.productId, 'pdf-epub'),
        ),
      )
      .limit(1);
    owns = !!hit;
  } catch (e) {
    console.warn('[shop] ownership check failed', e);
  }
}

interface Edition {
  format: string;
  price: string;
  description: string;
  badge: string;
  icon: string;
  href?: string;
  directPurchase?: boolean;
}

const editions: Edition[] = [
  {
    format: 'Kindle',
    price: '$9.99',
    description: 'Read on any Kindle device or app.',
    badge: 'Digital',
    icon: '📱',
    href: 'https://www.amazon.com/Sailors-Reminiscences-Days-Sailships-ebook/dp/B0FLY96HSZ',
  },
  {
    format: 'Paperback',
    price: '$17.99',
    description: 'Soft cover, perfect for reading at sea.',
    badge: 'Print',
    icon: '📖',
    href: 'https://www.amazon.com/Sailors-Reminiscences-Days-Sailships/dp/B0GW85ZGFN',
  },
  {
    format: 'Hardcover',
    price: '$24.99',
    description: 'A lasting keepsake edition.',
    badge: 'Print',
    icon: '📕',
    href: 'https://www.amazon.com/Sailors-Reminiscences-Days-Sailships/dp/B0GW88THSK',
  },
  {
    format: 'PDF / ePub',
    price: '$7.49',
    description: 'DRM-free download, read anywhere.',
    badge: 'Direct',
    icon: '⬇',
    directPurchase: true,
  },
];
---
<BaseLayout
  title="Shop"
  description="Purchase A Sailor's Reminiscences from the Days of the Sailships — Kindle, paperback, hardcover, or direct PDF/ePub download."
>
  <div class="max-w-shell mx-auto px-6 py-16 md:py-24">
    <div class="max-w-measure mx-auto text-center mb-16">
      <p class="eyebrow mb-4">Own the complete memoir</p>
      <h1
        class="font-display text-4xl md:text-5xl leading-tight text-ink mb-6"
        style="font-feature-settings: 'ss01'"
      >
        Shop
      </h1>
      <p class="font-serif text-lg text-ink-muted leading-relaxed max-w-prose mx-auto">
        <em>A Sailor&rsquo;s Reminiscences from the Days of the Sailships</em>
        is available in multiple formats. Read the full memoir online for free,
        or take it with you in print or as a DRM-free direct download.
      </p>
    </div>

    <div class="max-w-xs mx-auto mb-16">
      <div class="relative aspect-[2/3] rounded-lg overflow-hidden shadow-lift">
        <img
          src="/images/amazon_kdp_hardcover.jpg"
          alt="A Sailor's Reminiscences from the Days of the Sailships — book cover"
          loading="eager"
          class="absolute inset-0 w-full h-full object-cover"
        />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-shell mx-auto">
      {editions.map((ed) => (
        <div class="relative flex flex-col rounded-lg border border-rule-soft bg-bg-elev overflow-hidden">
          <div class="p-6 flex-1 flex flex-col">
            <div class="flex items-center justify-between mb-4">
              <span class="text-3xl" aria-hidden>{ed.icon}</span>
              <span class="eyebrow text-[10px]">{ed.badge}</span>
            </div>
            <h3 class="font-display text-2xl text-ink mb-2" style="font-feature-settings: 'ss01'">
              {ed.format}
            </h3>
            <p class="font-serif text-sm text-ink-muted leading-relaxed flex-1">
              {ed.description}
            </p>
            <p class="font-display text-2xl text-ink mt-4">{ed.price}</p>
          </div>
          <div class="border-t border-rule-soft p-4">
            {ed.directPurchase ? (
              owns ? (
                <div class="grid grid-cols-2 gap-2">
                  <a
                    href="/api/download/pdf-epub?format=pdf"
                    class="h-10 inline-flex items-center justify-center rounded-md bg-accent text-bg font-sans text-xs tracking-wider uppercase hover:bg-accent-hi transition-colors"
                  >Get PDF</a>
                  <a
                    href="/api/download/pdf-epub?format=epub"
                    class="h-10 inline-flex items-center justify-center rounded-md border border-rule text-ink font-sans text-xs tracking-wider uppercase hover:border-accent hover:text-accent transition-colors"
                  >Get ePub</a>
                </div>
              ) : (
                <button
                  type="button"
                  data-buy-direct
                  class="w-full h-10 inline-flex items-center justify-center rounded-md bg-accent text-bg font-sans text-xs tracking-wider uppercase hover:bg-accent-hi transition-colors"
                >
                  {user ? 'Buy now' : 'Sign in to buy'}
                </button>
              )
            ) : (
              <a
                href={ed.href}
                target="_blank"
                rel="noopener noreferrer"
                class="w-full h-10 inline-flex items-center justify-center rounded-md border border-rule text-ink font-sans text-xs tracking-wider uppercase hover:border-accent hover:text-accent transition-colors"
              >
                Buy on Amazon
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <script is:inline define:vars={{ isSignedIn: !!user }}>
    document.querySelectorAll('[data-buy-direct]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!isSignedIn) {
          const opener = document.querySelector('[data-open-signin]');
          if (opener instanceof HTMLElement) opener.click();
          return;
        }
        try {
          const res = await fetch('/api/checkout', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ slug: 'pdf-epub' }),
          });
          const json = await res.json();
          if (json.url) window.location.href = json.url;
          else alert(json.error || 'Checkout could not start.');
        } catch (e) {
          alert('Checkout failed. Try again.');
        }
      });
    });
  </script>
</BaseLayout>
