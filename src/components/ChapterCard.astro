---
// Compact card for the chapter grid on /. Cover thumb + ordinal + title.

import type { CollectionEntry } from 'astro:content';

interface Props {
  chapter: CollectionEntry<'chapters'>;
  ordinal: number;
}

const { chapter, ordinal } = Astro.props;

function toRoman(num: number): string {
  if (num <= 0) return '';
  const map: [number, string][] = [
    [1000, 'M'], [900, 'CM'], [500, 'D'], [400, 'CD'],
    [100, 'C'], [90, 'XC'], [50, 'L'], [40, 'XL'],
    [10, 'X'], [9, 'IX'], [5, 'V'], [4, 'IV'], [1, 'I'],
  ];
  let n = num;
  let out = '';
  for (const [v, s] of map) while (n >= v) { out += s; n -= v; }
  return out;
}
---
<a
  href={`/chapters/${chapter.data.slug}`}
  class="chapter-card group relative flex flex-col overflow-hidden rounded-lg border border-rule-soft bg-bg-elev hover:border-rule transition-colors"
>
  <div class="relative aspect-[1200/630] bg-bg-sunk overflow-hidden">
    {chapter.data.hero?.image && (
      <img
        src={chapter.data.hero.image}
        alt=""
        loading="lazy"
        class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-[filter] duration-500"
      />
    )}
  </div>
  <div class="p-5 flex-1 flex flex-col">
    <p class="eyebrow mb-2">Chapter {toRoman(ordinal)}</p>
    <h3
      class="font-display text-xl leading-tight text-ink group-hover:text-accent transition-colors"
      style="font-feature-settings: 'ss01'"
    >
      {chapter.data.title}
    </h3>
  </div>
</a>
